+package openapi_test
+
+import (
+	"mokapi/engine/common"
+	"mokapi/providers/openapi"
+	"mokapi/providers/openapi/openapitest"
+	"testing"
+
+	"github.com/stretchr/testify/require"
+)
+
+func TestCallback_Do(t *testing.T) {
+	testcases := []struct {
+		name     string
+		callback openapi.Callback
+		test     func(t *testing.T, cb openapi.Callback)
+	}{
+		{
+			name: "method not defined",
+			callback: map[string]*openapi.Path{
+				"": openapitest.NewPath(),
+			},
+			test: func(t *testing.T, cb openapi.Callback) {
+				res := cb.Do(&common.CallbackRequest{
+					Method: "GET",
+				})
+				require.Len(t, res, 1)
+				require.EqualError(t, res[0].Error, "Method GET not defined")
+			},
+		},
+	}
+
+	for _, tc := range testcases {
+		t.Run(tc.name, func(t *testing.T) {
+			tc.test(t, tc.callback)
+		})
+	}
+}
