+package openapi
+
+import (
+	"bytes"
+	"fmt"
+	"io"
+	"maps"
+	"mokapi/config/dynamic"
+	"mokapi/engine/common"
+	"mokapi/media"
+	"net/http"
+	"slices"
+	"strings"
+
+	log "github.com/sirupsen/logrus"
+)
+
+// Callback Key is expression
+type Callback map[string]*Path
+
+func (c *Callback) Parse(config *dynamic.Config, reader dynamic.Reader) error {
+	for name, p := range *c {
+		if err := p.Parse(config, reader); err != nil {
+			return fmt.Errorf("parse callback '%v' failed: %w", name, err)
+		}
+	}
+	return nil
+}
+
+func (c *Callback) patch(patch Callback) {
+	for name, p := range patch {
+		if path, ok := (*c)[name]; ok {
+			path.patch(p)
+		}
+	}
+}
+
+func (c *Callback) Do(r *common.CallbackRequest) []*common.CallbackResult {
+	var results []*common.CallbackResult
+	for url, p := range *c {
+		res, err := p.invoke(url, r)
+		results = append(results, &common.CallbackResult{Response: res, Error: err})
+	}
+	return results
+}
+
+func (p *Path) invoke(url string, r *common.CallbackRequest) (*http.Response, error) {
+	op := p.Operation(r.Method)
+	if op == nil {
+		allowed := slices.Collect(maps.Keys(p.Operations()))
+		return nil, newMethodNotAllowedErrorf(allowed, "Method %s not defined", r.Method)
+	}
+
+	var body io.Reader
+	if r.Body != nil && op.RequestBody != nil && op.RequestBody.Value != nil {
+		contentType := media.ParseContentType(r.Headers.Get("content-type"))
+		_, mt := getMedia(contentType, op.RequestBody.Value)
+		if !contentType.IsEmpty() && mt == nil {
+			supported := slices.Collect(maps.Keys(op.RequestBody.Value.Content))
+			errHttp := newHttpErrorf(http.StatusUnsupportedMediaType, "Unsupported Content-Type: %s\nThis operation only accepts: %s\nPlease set the Content-Type header to one of the supported types.", contentType.String(), strings.Join(supported, ", "))
+			return nil, errHttp
+		}
+		b, err := mt.Schema.Marshal(r.Body, contentType)
+		if err != nil {
+			return nil, err
+		}
+		body = bytes.NewReader(b)
+	}
+
+	req, err := http.NewRequest(r.Method, url, body)
+	if err != nil {
+		return nil, err
+	}
+
+	params := append(op.Path.Parameters, op.Parameters...)
+	for _, ref := range params {
+		if ref.Value == nil {
+			continue
+		}
+		pv := ref.Value
+		var err error
+		switch pv.Type {
+		case ParameterCookie:
+			_, err = parseCookie(pv, req)
+			if err != nil {
+				return nil, fmt.Errorf("parse cookie parameter '%v' failed: %w", pv.Name, err)
+			}
+		case ParameterHeader:
+			_, err = parseHeader(pv, req)
+			if err != nil {
+				return nil, fmt.Errorf("parse header parameter '%v' failed: %w", pv.Name, err)
+			}
+		case ParameterQueryString:
+			_, err = parseQueryString(pv, req)
+			if err != nil {
+				return nil, fmt.Errorf("parse querystring parameter '%v' failed: %w", pv.Name, err)
+			}
+		}
+	}
+
+	c := &http.Client{
+		Timeout: r.Timeout,
+		CheckRedirect: func(req *http.Request, via []*http.Request) error {
+			if l := len(via); l > r.MaxRedirects {
+				log.Warnf("Stopped after %d redirects, original URL was %s", r.MaxRedirects, via[0].URL)
+				return http.ErrUseLastResponse
+			}
+			return nil
+		},
+	}
+	return c.Do(req)
+}
